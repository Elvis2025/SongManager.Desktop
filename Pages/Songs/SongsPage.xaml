<?xml version="1.0" encoding="utf-8" ?>
<pages:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       x:Class="SongManager.Desktop.Pages.Songs.SongsPage"
                       xmlns:pages="clr-namespace:SongManager.Desktop.Pages"
                       xmlns:pageModel="clr-namespace:SongManager.Desktop.PageModels"
                       x:TypeArguments="pageModel:SongsPageModel"
                       Shell.TabBarIsVisible="False"
                       Background="{StaticResource PageBackgroundGradient}">

    <Grid Padding="16,12,16,0" RowSpacing="10" RowDefinitions="Auto,Auto,Auto,*,Auto" x:Name="PageRoot">
        <Label Text="♪"
               Style="{StaticResource WatermarkLabel}"
               HorizontalOptions="End"
               VerticalOptions="Start"
               Margin="0,-26,-10,0" />

        <Border x:Name="HeroCard" Style="{StaticResource GlassCard}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                <Label Text="Panel de Canciones" Style="{StaticResource HeroTitle}" />
                <Label Grid.Row="1" Text="Busca, filtra y gestiona canciones con rapidez." Style="{StaticResource HeroSubtitle}" />
                <Button Grid.Column="1" Grid.RowSpan="2" VerticalOptions="Center" Text="+ Nueva" Style="{StaticResource PrimaryActionButton}" Command="{Binding CreateSongCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <Border x:Name="StatsCard1" Style="{StaticResource GlassCard}">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Total en biblioteca" FontSize="11" Opacity="0.8" />
                    <Label Text="{Binding SongsList.Count}" Style="{StaticResource StatNumber}" />
                </VerticalStackLayout>
            </Border>
            <Border x:Name="StatsCard2" Grid.Column="1" Style="{StaticResource GlassCard}">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Cantantes" FontSize="11" Opacity="0.8" />
                    <Label Text="{Binding Singers.Count}" Style="{StaticResource StatNumber}" />
                </VerticalStackLayout>
            </Border>
            <Border x:Name="StatsCard3" Grid.Column="2" Style="{StaticResource GlassCard}">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Filtradas" FontSize="11" Opacity="0.8" />
                    <Label Text="{Binding Songs.Count}" Style="{StaticResource StatNumber}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Border x:Name="FilterCard" Grid.Row="2" Style="{StaticResource GlassCard}">
            <Grid ColumnDefinitions="1.4*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                <Border Grid.ColumnSpan="2" Style="{StaticResource FieldShell}">
                    <Entry x:Name="txtSong" Placeholder="Buscar canción por nombre..." TextChanged="FilterSongsBySong" ClearButtonVisibility="WhileEditing" BackgroundColor="Transparent" />
                </Border>

                <Border Grid.Row="1" Style="{StaticResource FieldShell}">
                    <Picker x:Name="pkSingers" Title="Filtrar por cantante" ItemsSource="{Binding Singers}" ItemDisplayBinding="{Binding FullName}" SelectedIndexChanged="FilterSongsBySinger" />
                </Border>

                <Button Grid.Row="1" Grid.Column="1" Text="Refrescar" Style="{StaticResource SecondaryActionButton}" Command="{Binding RefreshCommand}" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="3" Command="{Binding RefreshCommand}">
            <CollectionView x:Name="SongsCollection" ItemsSource="{Binding Songs}" SelectionMode="None" Margin="0,2,0,6">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                <Label Text="{Binding SongName}" FontSize="17" FontAttributes="Bold" />
                                <Border Grid.Column="1" Style="{StaticResource SoftChip}">
                                    <Label Text="{Binding Key}" FontSize="12" FontAttributes="Bold" />
                                </Border>

                                <Label Grid.Row="1" Text="{Binding SongAuthor, StringFormat='Autor: {0}'}" TextColor="{AppThemeBinding Light=#5C668D, Dark=#B6C0E4}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding SingerName}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#3B4B99, Dark=#C9D2FF}" />

                                <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
                                    <Button Text="Editar" Style="{StaticResource SecondaryActionButton}" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditSongCommand}" CommandParameter="{Binding .}" />
                                    <Button Grid.Column="1" Text="Eliminar" BackgroundColor="{AppThemeBinding Light=#FEE3E3, Dark=#54283A}" TextColor="{AppThemeBinding Light=#B42318, Dark=#FFC0CF}" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteSongCommand}" CommandParameter="{Binding .}" />
                                    <Button Grid.Column="2" Text="Abrir Link" Style="{StaticResource PrimaryActionButton}" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenLinkSongCommand}" CommandParameter="{Binding Link}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource GlassCard}">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                            <Label Text="🎵" FontSize="38" HorizontalTextAlignment="Center" />
                            <Label Text="No hay canciones para mostrar" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Text="Crea una canción nueva o limpia los filtros para continuar." FontSize="13" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light=#5A6389, Dark=#BAC3E5}" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <Border Grid.Row="4" x:Name="BottomNav" Style="{StaticResource FloatingBottomBar}">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Text="Canciones" Style="{StaticResource PrimaryActionButton}" Clicked="GoSongs_Clicked" />
                <Button Grid.Column="1" Text="Cantantes" Style="{StaticResource SecondaryActionButton}" Clicked="GoSingers_Clicked" />
                <Button Grid.Column="2" Text="Usuarios" Style="{StaticResource SecondaryActionButton}" Clicked="GoUsers_Clicked" />
            </Grid>
        </Border>
    </Grid>
</pages:BaseContentPage>
