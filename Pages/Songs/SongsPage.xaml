<?xml version="1.0" encoding="utf-8" ?>
<pages:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       x:Class="SongManager.Desktop.Pages.Songs.SongsPage"
                       xmlns:pages="clr-namespace:SongManager.Desktop.Pages"
                       xmlns:pageModel="clr-namespace:SongManager.Desktop.PageModels"
                       xmlns:icon="clr-namespace:SongManager.Desktop.UsesCases.IconFont"
                       x:TypeArguments="pageModel:SongsPageModel"
                       Background="{StaticResource PageBackgroundGradient}">

    <Grid x:Name="PageRoot" RowDefinitions="Auto,Auto,*" Padding="22" RowSpacing="16">
        <Label Text="♪"
               Style="{StaticResource WatermarkLabel}"
               HorizontalOptions="End"
               VerticalOptions="Start"
               Margin="0,-26,-10,0" />

        <Border Style="{StaticResource ModernCard}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                <Label Text="Biblioteca de Canciones" Style="{StaticResource HeroTitle}" />
                <Label Grid.Row="1"
                       Text="Gestiona repertorio, enlaces y tonalidades con una experiencia moderna."
                       Style="{StaticResource HeroSubtitle}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}">
            <Grid ColumnDefinitions="*,220,Auto" ColumnSpacing="12">
                <Entry x:Name="txtSong"
                       Placeholder="Buscar por canción..."
                       TextChanged="FilterSongsBySong"
                       ClearButtonVisibility="WhileEditing" />

                <Picker x:Name="pkSingers"
                        Grid.Column="1"
                        Title="Cantante"
                        ItemsSource="{Binding Singers}"
                        ItemDisplayBinding="{Binding FullName}"
                        SelectedIndexChanged="FilterSongsBySinger" />

                <Button Grid.Column="2"
                        Text="＋"
                        WidthRequest="48"
                        HeightRequest="48"
                        Style="{StaticResource PrimaryActionButton}"
                        Command="{Binding CreateSongCommand}" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Songs}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ModernCard}" Margin="0,0,0,12">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8">
                                <Label Text="{Binding SongName}" FontSize="20" FontAttributes="Bold" />
                                <Border Grid.Column="1" Style="{StaticResource SoftChip}">
                                    <Label Text="{Binding Key}" FontAttributes="Bold" FontSize="12"/>
                                </Border>

                                <Label Grid.Row="1"
                                       Text="{Binding SingerName}"
                                       TextColor="{AppThemeBinding Light=#4E5A84, Dark=#C6CEEF}" />

                                <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="10">
                                    <Button Text="Editar"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditSongCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Eliminar"
                                            BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#4B1F2C}"
                                            TextColor="{AppThemeBinding Light=#B42318, Dark=#FFC0C8}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteSongCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="YouTube"
                                            BackgroundColor="{AppThemeBinding Light=#E8ECFF, Dark=#2A3560}"
                                            TextColor="{AppThemeBinding Light=#2D3FA0, Dark=#BEC8FF}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenLinkSongCommand}"
                                            CommandParameter="{Binding Link}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource ModernCard}">
                        <Label Text="Aún no hay canciones. Crea la primera con el botón +."
                               HorizontalTextAlignment="Center" />
                    </Border>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</pages:BaseContentPage>
