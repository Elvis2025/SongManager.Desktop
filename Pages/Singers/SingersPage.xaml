<?xml version="1.0" encoding="utf-8" ?>
<pages:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       x:Class="SongManager.Desktop.Pages.Singers.SingersPage"
                       xmlns:pages="clr-namespace:SongManager.Desktop.Pages"
                       xmlns:pageModel="clr-namespace:SongManager.Desktop.PageModels"
                       x:TypeArguments="pageModel:SingersPageModel"
                       Background="{StaticResource PageBackgroundGradient}">

    <Grid x:Name="PageRoot" RowDefinitions="Auto,*" Padding="22" RowSpacing="16">
        <Label Text="♫"
               Style="{StaticResource WatermarkLabel}"
               HorizontalOptions="End"
               VerticalOptions="Start"
               Margin="0,-22,-8,0" />

        <Border Style="{StaticResource ModernCard}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                <Label Text="Gestión de Cantantes" Style="{StaticResource HeroTitle}" />
                <Label Grid.Row="1"
                       Text="Crea fichas vocales, edita perfiles y mantén tu equipo organizado."
                       Style="{StaticResource HeroSubtitle}" />
                <Button Grid.Column="1"
                        Grid.RowSpan="2"
                        VerticalOptions="Center"
                        Text="Nuevo"
                        Style="{StaticResource PrimaryActionButton}"
                        Command="{Binding CreateSingerCommand}" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="1" ItemsSource="{Binding SingersDto}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ModernCard}" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                            <Label Text="{Binding FullNameComplete}" FontSize="18" FontAttributes="Bold" />
                            <Border Grid.Column="1" Style="{StaticResource SoftChip}">
                                <Label Text="{Binding Code}" FontSize="11" FontAttributes="Bold"/>
                            </Border>

                            <HorizontalStackLayout Grid.Row="1" Spacing="8">
                                <Border Style="{StaticResource SoftChip}">
                                    <Label Text="{Binding Gender}" FontSize="12" />
                                </Border>
                                <Border Style="{StaticResource SoftChip}">
                                    <Label Text="{Binding VocalRange}" FontSize="12" />
                                </Border>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                <Button Text="Editar"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditSingerCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Eliminar"
                                        BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#4B1F2C}"
                                        TextColor="{AppThemeBinding Light=#B42318, Dark=#FFC0C8}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteSingerCommand}"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Border Style="{StaticResource ModernCard}">
                    <Label Text="No hay cantantes registrados todavía."
                           HorizontalTextAlignment="Center" />
                </Border>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</pages:BaseContentPage>
