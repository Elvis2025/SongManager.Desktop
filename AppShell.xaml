<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SongManager.Desktop.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.SegmentedControl;assembly=Syncfusion.Maui.Toolkit"
    xmlns:songs="clr-namespace:SongManager.Desktop.Pages.Songs"
    xmlns:singers="clr-namespace:SongManager.Desktop.Pages.Singers"
    xmlns:users="clr-namespace:SongManager.Desktop.Pages.Users"
    FlyoutBehavior="Flyout"
    Shell.NavBarIsVisible="False">

    <Shell.FlyoutHeader>
        <Grid Padding="20" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#171F3A}">
            <Label Text="SongManager" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#141C3A, Dark=#F2F4FF}" />
            <Label Grid.Row="1" Text="Studio Control" FontSize="16" TextColor="{AppThemeBinding Light=#3A4B91, Dark=#AAB8FF}" />
            <Label Grid.Row="2" Text="Gestiona repertorio, cantantes y enlaces de forma profesional." FontSize="13" Opacity="0.8" TextColor="{AppThemeBinding Light=#5F6A93, Dark=#C2CAE7}" />
        </Grid>
    </Shell.FlyoutHeader>

    <ShellContent Title="Canciones" Icon="{StaticResource IconProjects}" ContentTemplate="{DataTemplate songs:SongsPage}" Route="SongsPage" />
    <ShellContent Title="Cantantes" Icon="{StaticResource IconDashboard}" ContentTemplate="{DataTemplate singers:SingersPage}" Route="SingersPage" />
    <ShellContent Title="Usuarios" Icon="{StaticResource IconMeta}" ContentTemplate="{DataTemplate users:UserPage}" Route="UserPage" />

    <Shell.FlyoutFooter>
        <Grid Padding="14" BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#171F3A}">
            <sf:SfSegmentedControl x:Name="ThemeSegmentedControl"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   SegmentWidth="58"
                                   SegmentHeight="46"
                                   SelectionChanged="SfSegmentedControl_SelectionChanged">
                <sf:SfSegmentedControl.ItemsSource>
                    <x:Array Type="{x:Type sf:SfSegmentItem}">
                        <sf:SfSegmentItem ImageSource="{StaticResource IconLight}" />
                        <sf:SfSegmentItem ImageSource="{StaticResource IconDark}" />
                    </x:Array>
                </sf:SfSegmentedControl.ItemsSource>
            </sf:SfSegmentedControl>
        </Grid>
    </Shell.FlyoutFooter>

</Shell>
