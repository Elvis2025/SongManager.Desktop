<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:f="clr-namespace:SongManager.Desktop.UsesCases.IconFont"
    xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <x:Double x:Key="sizeNone">0</x:Double>
    <x:Double x:Key="size20">2</x:Double>
    <x:Double x:Key="size40">4</x:Double>
    <x:Double x:Key="size60">6</x:Double>
    <x:Double x:Key="size80">8</x:Double>
    <x:Double x:Key="size100">10</x:Double>
    <x:Double x:Key="size120">12</x:Double>
    <x:Double x:Key="size160">16</x:Double>
    <x:Double x:Key="size200">20</x:Double>
    <x:Double x:Key="size240">24</x:Double>
    <x:Double x:Key="size280">28</x:Double>
    <x:Double x:Key="size320">32</x:Double>
    <x:Double x:Key="size360">36</x:Double>
    <x:Double x:Key="size400">40</x:Double>
    <x:Double x:Key="size480">48</x:Double>
    <x:Double x:Key="size520">52</x:Double>
    <x:Double x:Key="size560">56</x:Double>

    <OnIdiom x:Key="IconSize" x:TypeArguments="x:Double" Default="20">
        <OnIdiom.Desktop>30</OnIdiom.Desktop>
    </OnIdiom>

    <OnIdiom x:Key="IconSizeSmall" x:TypeArguments="x:Double" Default="12">
        <OnIdiom.Desktop>18</OnIdiom.Desktop>
    </OnIdiom>

    <OnIdiom x:Key="LayoutPadding" x:TypeArguments="Thickness" Default="15">
        <OnIdiom.Desktop>28</OnIdiom.Desktop>
    </OnIdiom>

    <OnIdiom x:Key="LayoutSpacing" x:TypeArguments="x:Double" Default="6">
        <OnIdiom.Desktop>14</OnIdiom.Desktop>
    </OnIdiom>

    <FontImageSource x:Key="IconDashboard" Glyph="{x:Static f:FluentUI.Ic_fluent_diagram_24_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}" Color="{AppThemeBinding Light=#1D254A, Dark=#E6E9FF}" Size="{StaticResource IconSize}" />
    <FontImageSource x:Key="IconProjects" Glyph="{x:Static f:FluentUI.Ic_fluent_music_note_2_24_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}" Color="{AppThemeBinding Light=#1D254A, Dark=#E6E9FF}" Size="{StaticResource IconSize}" />
    <FontImageSource x:Key="IconMeta" Glyph="{x:Static f:FluentUI.Ic_fluent_person_24_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}" Color="{AppThemeBinding Light=#1D254A, Dark=#E6E9FF}" Size="{StaticResource IconSize}" />
    <FontImageSource x:Key="IconLight" Glyph="{x:Static f:FluentUI.Ic_fluent_weather_sunny_28_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}" Color="{AppThemeBinding Light=#171A2B, Dark=#E6E9FF}" Size="{StaticResource size240}" />
    <FontImageSource x:Key="IconDark" Glyph="{x:Static f:FluentUI.Ic_fluent_weather_moon_28_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}" Color="{AppThemeBinding Light=#171A2B, Dark=#E6E9FF}" Size="{StaticResource size240}" />

    <Style TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 14"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <sf:LabelStyle x:Key="lightThemeLabelStyle" TextColor="#212742" FontSize="{OnIdiom 16, Desktop=20}"/> 
    <sf:LabelStyle x:Key="darkThemeLabelStyle" TextColor="#E6E9FF" FontSize="{OnIdiom 16, Desktop=20}"/>
    <Style TargetType="sf:SfTextInputLayout"> 
        <Setter Property="ContainerType" Value="Outlined"/> 
        <Setter Property="ContainerBackground" Value="Transparent"/> 
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#CBD5FF, Dark=#3A456E}"/> 
        <Setter Property="HintLabelStyle" Value="{AppThemeBinding Light={StaticResource lightThemeLabelStyle}, Dark={StaticResource darkThemeLabelStyle}}"/> 
    </Style>

    <Style TargetType="pullToRefresh:SfPullToRefresh">
        <Setter Property="TransitionMode" Value="SlideOnTop"/>
        <Setter Property="PullingThreshold" Value="100"/>
        <Setter Property="ProgressColor" Value="#635BFF"/>
    </Style>

    <LinearGradientBrush x:Key="PageBackgroundGradient" EndPoint="1,1">
        <GradientStop Color="{AppThemeBinding Light=#F6F8FF, Dark=#0C1020}" Offset="0" />
        <GradientStop Color="{AppThemeBinding Light=#EEF1FF, Dark=#151C33}" Offset="0.55" />
        <GradientStop Color="{AppThemeBinding Light=#E7ECFF, Dark=#1D2542}" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{AppThemeBinding Light=#FFFFFF, Dark=#1B2340}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#DDE4FF, Dark=#33406A}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{AppThemeBinding Light=#1A2A6840, Dark=#00000070}" Offset="0,8" Radius="18" Opacity="0.35" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeroTitle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#141B36, Dark=#F1F4FF}" />
    </Style>

    <Style x:Key="HeroSubtitle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#596287, Dark=#B8C1E4}" />
        <Setter Property="Opacity" Value="0.95" />
    </Style>

    <Style x:Key="WatermarkLabel" TargetType="Label">
        <Setter Property="FontSize" Value="86" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Rotation" Value="-12" />
        <Setter Property="Opacity" Value="0.03" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#2D44C7, Dark=#AAB8FF}" />
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#5E55FA, Dark=#8D86FF}" />
        <Setter Property="TextColor" Value="White" />
    </Style>

    <Style x:Key="SecondaryActionButton" TargetType="Button">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#ECF0FF, Dark=#2C3659}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#2B3EA0, Dark=#D3DBFF}" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="SoftChip" TargetType="Border">
        <Setter Property="Background" Value="{AppThemeBinding Light=#EEF2FF, Dark=#2A355A}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="Padding" Value="10,5" />
    </Style>

    <Style x:Key="StatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#172048, Dark=#EEF2FF}" />
    </Style>

    <Style x:Key="FieldShell" TargetType="Border">
        <Setter Property="Background" Value="{AppThemeBinding Light=#F8FAFF, Dark=#1E2745}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#D8E0FF, Dark=#36456F}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="FloatingBottomBar" TargetType="Border">
        <Setter Property="Background" Value="{AppThemeBinding Light=#FFFFFF, Dark=#1A2443}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#D7E0FF, Dark=#36456F}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="24,0,24,12" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{AppThemeBinding Light=#1A2A6840, Dark=#00000070}" Offset="0,10" Radius="20" Opacity="0.4" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
